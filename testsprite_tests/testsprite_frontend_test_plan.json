  {
    "id": "TC006",
    "title": "Resolve a missing document successfully (optimistic removal persists)",
    "description": "Verifies that resolving a missing document removes it immediately and it stays removed after backend confirmation.",
    "category": "Admin Dashboard - Missing Documents (Optimistic Resolve)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username or email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"MissingDocsTracker\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Resolve\" button on the first missing document in the MissingDocsTracker list"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Unable to resolve, try again\" is not visible"
      }
    ]
  },
