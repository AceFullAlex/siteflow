[
  {
    "id": "TC001",
    "title": "Switch to Action Center tab and view summary content",
    "description": "Verifies an admin can open the dashboard and view Action Center content after switching tabs.",
    "category": "Admin Dashboard - Tabs",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username or email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password or PIN field"
      },
      {
        "type": "action",
        "description": "Click on the \"Sign in\" or \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on Action Center tab"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Action Center\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"stats\" is visible"
      }
    ]
  },
